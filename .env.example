# ============================================
# 環境變數設定 (請複製此檔案為 .env 並修改)
# ============================================

# MySQL 資料庫
MYSQL_ROOT_PASSWORD=your_mysql_password
MYSQL_DATABASE=grape_shop
DB_USER=root

# Django
DJANGO_SECRET_KEY=your-django-secret-key
DJANGO_DEBUG=True

# LINE Login（至 LINE Developers 取得）
LINE_CHANNEL_ID=your-line-channel-id
LINE_CHANNEL_SECRET=your-line-channel-secret
LINE_CALLBACK_URL=http://localhost:3000/login/line-callback

# Google Login（至 Google Cloud Console 取得）
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/login/google-callback

# Email (Gmail SMTP，需開啟兩步驗證後產生 App Password)
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password

# ECPay 綠界金流（測試環境，正式上線請更換）
ECPAY_MERCHANT_ID=3002607
ECPAY_HASH_KEY=***REMOVED_ECPAY_KEY***
ECPAY_HASH_IV=***REMOVED_ECPAY_IV***
ECPAY_PAYMENT_URL=https://payment-stage.ecpay.com.tw/Cashier/AioCheckOut/V5

# Cloudinary 圖片儲存（選填，未設定則使用本機儲存）
# CLOUD_NAME=your-cloud-name
# API_KEY=your-api-key
# API_SECRET=your-api-secret

# 網站網址
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
