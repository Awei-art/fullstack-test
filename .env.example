# ============================================
# 環境變數設定 (請複製此檔案為 .env 並修改)
# ============================================

# MySQL 資料庫
MYSQL_ROOT_PASSWORD=***REMOVED_DB_PASSWORD***
MYSQL_DATABASE=grape_shop
DB_USER=root

# Django
DJANGO_SECRET_KEY=your-secret-key-change-this-in-production
DJANGO_DEBUG=True
